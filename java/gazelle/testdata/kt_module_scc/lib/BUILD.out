load("@rules_kotlin//kotlin:jvm.bzl", "kt_jvm_library")

# gazelle:jvm_kotlin_enabled true
# gazelle:java_module_granularity scc

kt_jvm_library(
    name = "base",
    srcs = ["base/Base.kt"],
    module_name = "lib",
    visibility = ["//:__subpackages__"],
)

kt_jvm_library(
    name = "cyclea",
    srcs = [
        "cyclea/CycleA.kt",
        "cycleb/CycleB.kt",
    ],
    module_name = "lib",
    visibility = ["//:__subpackages__"],
)

kt_jvm_library(
    name = "secret",
    srcs = [
        "secret/Secret.kt",
        "secretuser/SecretUser.kt",
    ],
    module_name = "lib",
    visibility = ["//:__subpackages__"],
)

kt_jvm_library(
    name = "solo",
    srcs = ["solo/Solo.kt"],
    module_name = "lib",
    visibility = ["//:__subpackages__"],
)

kt_jvm_library(
    name = "user",
    srcs = ["user/User.kt"],
    associates = [":base"],
    visibility = ["//:__subpackages__"],
)
